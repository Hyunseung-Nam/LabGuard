# LabGuard 서버 주소
API_URL=http://localhost:8000/api

# LabGuard에 등록된 장비 UUID (필수)
# 웹 대시보드 > 장비 관리 > 장비 클릭 > URL에서 확인
DEVICE_ID=여기에_장비_UUID_입력

# 드라이버 선택
# arduino_json  : Arduino 에뮬레이터 테스트용
# jeiotech      : JEIO TECH 항온항습기 실제 연결
DRIVER=arduino_json

# 시리얼 포트
# auto          : 자동 감지 (권장)
# 직접 지정 예시: /dev/tty.usbserial-XXXX  (Mac)
#                COM3                       (Windows)
SERIAL_PORT=auto
SERIAL_BAUD_RATE=9600

# 동작 설정
POLL_INTERVAL=5    # 측정 주기 (초)
RETRY_INTERVAL=10  # 연결 실패 시 재시도 대기 (초)
